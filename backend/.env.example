# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_merchant

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key
SUPABASE_JWT_SECRET=your-jwt-secret

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# AI Provider: huggingface, together, runpod, replicate
AI_PROVIDER=huggingface

# HuggingFace API Token (FREE tier - get from https://huggingface.co/settings/tokens)
HUGGINGFACE_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Together AI API Key (optional - get from https://api.together.xyz)
TOGETHER_API_KEY=

# RunPod (optional - get from https://runpod.io)
RUNPOD_ENDPOINT_URL=
RUNPOD_API_KEY=

# Replicate (optional - get from https://replicate.com)
REPLICATE_API_TOKEN=

# Server
RUST_LOG=info
PORT=3000
