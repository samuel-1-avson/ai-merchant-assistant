# =============================================================================
# AI Merchant Assistant - Environment Configuration Template
# Copy this file to .env and fill in your actual values
# ⚠️ NEVER COMMIT .env TO GIT!
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration (Supabase PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-eu-west-1.pooler.supabase.com:5432/postgres

# Optional: Redis for distributed rate limiting (production)
# REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Supabase Configuration
# Get from: https://app.supabase.com/project/_/settings/api
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_ANON_KEY=your-anon-key

# -----------------------------------------------------------------------------
# AI Provider Configuration (Failover System)
# Chain: HuggingFace → Together AI → RunPod
# -----------------------------------------------------------------------------
AI_PROVIDER=huggingface

# Primary: HuggingFace (FREE tier available)
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=hf_your_token_here

# Failover 1: Together AI (optional)
# Get from: https://www.together.ai/
TOGETHER_API_KEY=

# Failover 2: RunPod (optional)
# Get from: https://www.runpod.io/
RUNPOD_ENDPOINT_URL=
RUNPOD_API_KEY=

# OCR Service (optional)
EASYOCR_URL=

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long

# Rate Limiting (requests per minute)
RATE_LIMIT_AI_REQUESTS=20
RATE_LIMIT_AUTH_REQUESTS=10
RATE_LIMIT_DEFAULT_REQUESTS=100

# -----------------------------------------------------------------------------
# OAuth Configuration (Social Login)
# -----------------------------------------------------------------------------
# Google OAuth - Get from https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth - Get from https://github.com/settings/applications/new
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# -----------------------------------------------------------------------------
# Alert Configuration
# -----------------------------------------------------------------------------
ALERT_LOW_STOCK_THRESHOLD=10
ALERT_CHECK_INTERVAL_MINUTES=60

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_BACKEND_URL=http://localhost:8888
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_OCR=true
ENABLE_ALERTS=true
ENABLE_MULTI_PRODUCT=true
ENABLE_FUZZY_MATCHING=true
ENABLE_RATE_LIMITING=true
